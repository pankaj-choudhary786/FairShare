# Run from fairshare/backend: npm run dev
# SQL for Supabase lives in ./db/ (schema + migrations)

PORT=4000
FRONTEND_URL=http://localhost:5173

# Supabase (same project as frontend; service role is server-only — never expose in Vite)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe (https://dashboard.stripe.com/apikeys — use test keys in development)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Create Products/prices in Stripe Dashboard → copy Price IDs
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# Webhook URL for local testing (Stripe CLI): stripe listen --forward-to localhost:4000/api/stripe/webhook
#
# One-off charity donations use POST /api/stripe/create-donation-session (same STRIPE_SECRET_KEY; no extra price IDs).
